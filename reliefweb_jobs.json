<script>
fetch('reliefweb_jobs (1).json')
  .then(response => response.json())
  .then(jobs => {
    const container = document.getElementById('job-cards-container');
    container.innerHTML = '';

    jobs.slice(0, 12).forEach(job => {
      const card = document.createElement('div');
      card.className = 'job-card bg-white rounded-lg shadow overflow-hidden border border-gray-100 p-6 flex flex-col justify-between transition transform hover:-translate-y-1 hover:shadow-lg';

      const title = job["Job Title"] || "بدون عنوان";
      const company = job["Company"] || "غير معروف";
      const location = job["Location"] || "غير محدد";
      const date = job["Date"] || "";
      const deadline = job["Deadline"] || "";
      const description = job["Description"] || "";
      const link = job["Link"] || "#";

      card.innerHTML = `
        <div class="mb-4">
          <h3 class="text-lg font-bold text-gray-800 mb-1">${title}</h3>
          <p class="text-sm text-gray-600 mb-2">${company}</p>
          <p class="text-sm text-gray-500 mb-2"><i class="fas fa-map-marker-alt mr-1"></i>${location}</p>
          ${description ? `<p class="text-sm text-gray-500 mb-2">${description.slice(0, 100)}...</p>` : ''}
          <div class="flex justify-between text-xs text-gray-400 mt-2">
            ${date ? `<span><i class="fas fa-calendar-alt mr-1"></i>تاريخ النشر: ${date}</span>` : ''}
            ${deadline ? `<span><i class="fas fa-hourglass-end mr-1"></i>الانتهاء: ${deadline}</span>` : ''}
          </div>
        </div>
        <div>
          <a href="${link}" target="_blank" class="inline-block bg-indigo-600 text-white px-4 py-2 rounded-md text-sm text-center hover:bg-indigo-700 transition">عرض التفاصيل</a>
        </div>
      `;
      container.appendChild(card);
    });
  });
</script>
